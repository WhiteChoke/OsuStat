<Application x:Class="OsuStat.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModel="clr-namespace:OsuStat.UI.MVVM.ViewModel"
             xmlns:view="clr-namespace:OsuStat.UI.MVVM.View">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/ScrollBarThumb.xaml"/>
                <ResourceDictionary Source="/Styles/ScrollBarStyle.xaml"/>
                <ResourceDictionary Source="/Styles/ExpanderStyle.xaml"/>
                <ResourceDictionary Source="/Styles/TextBlockStyle.xaml"/>
                <ResourceDictionary Source="/Styles/ButtonStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModel:HomeViewModel}">
                <view:HomeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModel:SettingsViewModel}">
                <view:SettingsView/>
            </DataTemplate>

            <SolidColorBrush x:Key="BackgroundBlack" Color="#1F2021"/>
            <SolidColorBrush x:Key="RaspberryRed" Color="#721D30"/>
            <SolidColorBrush x:Key="86Black" Color="#00000086" />
            <SolidColorBrush x:Key="LightGrayBackground" Color="#27292B"/>
            <SolidColorBrush x:Key="EllipseBlack" Color="#12121A"/>
        
            <FontFamily x:Key="Rubik">/Assets/Fonts/#Rubik</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
