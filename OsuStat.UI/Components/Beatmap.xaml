<UserControl x:Class="OsuStat.UI.Components.Beatmap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OsuStat.UI.Components"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    
    <Expander Style="{StaticResource BeatMapExpander}">
        <Expander.Header>
            <Border CornerRadius="5"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Margin="0 0 0 20"
                    Height="56"
                    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, 
           AncestorType={x:Type Expander}}, Path=ActualWidth}">
            <Border.Background>
                <ImageBrush ImageSource="{Binding BgPath}"
                            Stretch="UniformToFill"/>
            </Border.Background>
            <Grid Margin="15 0 9 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border HorizontalAlignment="Left"
                        Background="#86000000"
                        Width="130"
                        VerticalAlignment="Center"
                        Height="auto">
                    <TextBlock Text="{Binding Name}"
                               FontSize="26"
                               Padding="6 0 10 0"/>
                </Border>
                <Border HorizontalAlignment="Right"
                        Background="#86000000"
                        Width="auto"
                        Grid.Column="1"
                        Padding="2 2 4 2"
                        VerticalAlignment="Center"
                        Height="auto">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding StarRate}"
                                   FontSize="26"
                                   Margin="0 0 20 0"/>
                        <Image Source="/Assets/Images/Star.jpeg"  Width="24"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        </Expander.Header>
        <Expander.Content>
                <Border BorderThickness="1" 
                        Padding="10"
                        CornerRadius="17">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding BgPath}"
                                    Stretch="UniformToFill"/>                                     
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="10"
                                Background="#86000000"
                                Margin="0 0 0 20"
                                Padding="10 0">
                            <StackPanel Height="auto" Width="187" Margin="6" HorizontalAlignment="Left">
                                <TextBlock FontSize="26" Text="{Binding Name}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="18" Text="by "/>
                                    <TextBlock FontSize="18" Text="{Binding Artist}"/>
                                </StackPanel>
                                <StackPanel Margin="0 25 0 0" Orientation="Horizontal">
                                    <TextBlock FontSize="18" Text="Mapper: " />
                                    <TextBlock FontSize="18" Text="{Binding Mapper}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1"
                                CornerRadius="10"
                                Background="#86000000"
                                Padding="10 8">
                            <StackPanel Orientation="Horizontal">
                               <TextBlock FontSize="28" Text="played: "/>
                                <TextBlock FontSize="28" Text="{Binding PlayCount}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                CornerRadius="10"
                                Background="#86000000"
                                Width="auto"
                                Padding="7"
                                Height="auto"
                                Margin="0 0 0 20"
                                HorizontalAlignment="Right">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" >
                                    <TextBlock FontSize="26" HorizontalAlignment="Left" Text="Bpm "/>
                                    <TextBlock FontSize="26" HorizontalAlignment="Left" Text="{Binding Bpm}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock FontSize="18" HorizontalAlignment="Left" Text="Length "/>
                                    <TextBlock FontSize="18" HorizontalAlignment="Left" Text="{Binding Length}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock FontSize="18" HorizontalAlignment="Left" Text="Hp "/>
                                    <TextBlock FontSize="18" HorizontalAlignment="Left" Text="{Binding Hp}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="30 0 0 0">
                                    <TextBlock FontSize="26" Text="{Binding StarRate}"/>
                                    <Image Source="/Assets/Images/Star.jpeg" Height="24"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="30 0 0 0">
                                    <TextBlock FontSize="18" Text="Ar "/>
                                    <TextBlock FontSize="18" Text="{Binding Ar}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="30 0 0 0">
                                    <TextBlock FontSize="18" Text="Cs "/>
                                    <TextBlock FontSize="18" Text="{Binding Cs}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Button Grid.Row="1" Grid.Column="1"
                                Content="-"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding CollapseMenu}"/>
                    </Grid>
                </Border>
        </Expander.Content>
    </Expander>    
</UserControl>
