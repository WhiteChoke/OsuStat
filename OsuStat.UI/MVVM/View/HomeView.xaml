<UserControl x:Class="OsuStat.UI.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:view="clr-namespace:OsuStat.UI.MVVM.View"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBlack}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Margin="18 30 18 18">
            <Ellipse Height="60" Width="60" HorizontalAlignment="Left">
                <Ellipse.Fill>
                    <ImageBrush ImageSource="{Binding User.AvatarPath }" Stretch="UniformToFill" />
                </Ellipse.Fill>
            </Ellipse>
            <StackPanel VerticalAlignment="Bottom" Margin="15 0">
                <TextBlock Text="{Binding User.Nickname}" VerticalAlignment="Center" FontSize="26" />
                <TextBlock Text="{Binding User.GlobalRanking}" FontSize="16" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="30 19 20 45">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding SessionDate}" Margin="14" FontSize="48"/>
            <Border Grid.Row="1"
                    CornerRadius="14"
                    Background="{StaticResource RaspberryRed}"
                    Padding="34 100">
                <StackPanel Margin="0 0 24 0" VerticalAlignment="Center">
                    <TextBlock FontSize="25" Text="{Binding PlayerStat.PlayTimeMin, StringFormat='• Play time {0}'}"
                               Margin="0 10"/>
                    <TextBlock FontSize="25" Text="{Binding PlayerStat.MapPlayed, StringFormat='• Maps passed {0}'}"
                               Margin="0 10"/>
                    <TextBlock FontSize="25" Text="{Binding PlayerStat.PpGained, StringFormat='• PP gained {0}'}"
                               Margin="0 10"/>
                    <TextBlock FontSize="25" Text="{Binding PlayerStat.AvgBpm, StringFormat='• AVG Bpm {0}'}"
                               Margin="0 10"/>
                    <TextBlock FontSize="25" Text="{Binding PlayerStat.AvgStarRate, StringFormat='• AVG StarRate {0}'}"
                               Margin="0 10"/>
                    <TextBlock FontSize="25" Text="{Binding PlayerStat.AvgAccuracy, StringFormat='• AVG Accuracy {0}'}"
                               Margin="0 10"/>
                </StackPanel>
            </Border>
        </Grid>
        <Border Grid.RowSpan="2"
                Grid.Column="1"
                Background="{StaticResource SwagBlack}"
                CornerRadius="17"
                Margin="20">
            <ScrollViewer Margin="10 25">
                <ItemsControl ItemsSource="{Binding BeatMaps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <view:MapCard Margin="10"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>