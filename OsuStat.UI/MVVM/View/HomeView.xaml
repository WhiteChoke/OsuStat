<UserControl x:Class="OsuStat.UI.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OsuStat.UI.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="572"
             Background="{StaticResource BackgroundBlack}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="2"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="18 30 18 18">
                <Ellipse Height="60" Width="60" HorizontalAlignment="Left" >
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding User.AvatarPath }" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
                <StackPanel VerticalAlignment="Bottom" Margin="15 0">
                    <TextBlock Text="{Binding User.Nickname}" VerticalAlignment="Center" FontSize="26"/>
                    <TextBlock Text="{Binding User.GlobalRanking}" FontSize="16"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" 
                        Orientation="Horizontal"  Margin="22">
                <TextBlock Text="last session:" FontSize="26"/>
                <TextBlock Text="{Binding User.LastSession}" FontSize="17" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel  Grid.Row="1" Margin="24 0">
            <TextBlock Text="Today" FontSize="40"/>
                <TextBlock FontSize="20" Text="{Binding PlayTime}" Margin="6 0 0 10 "/>
                <TextBlock FontSize="20" Text="{Binding MapsPlayed}" Margin="6 0 0 10 "/>
                <TextBlock FontSize="20" Text="{Binding PpGained}" Margin="6 0 0 10 "/>
                <TextBlock FontSize="20" Text="{Binding AvgBpm}" Margin="6 0 0 10 "/>
                <TextBlock FontSize="20" Text="{Binding AvgStarRate}" Margin="6 0 0 10 "/>
                <TextBlock FontSize="20" Text="{Binding AvgAccuracy}" Margin="6 0 0 10 "/>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="1" HorizontalAlignment="Right" Margin="20 0">
                <TextBlock Text="Best score" FontSize="23"/>
                <Border Width="210" Height="210" 
                            CornerRadius="10" HorizontalAlignment="Left">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding MapAvatarPath}" Stretch="UniformToFill" />
                    </Border.Background>
                    <DockPanel VerticalAlignment="Bottom" Margin="8">
                        <Border  Width="auto" Height="auto" CornerRadius="4">
                            <Border.Background>
                                <SolidColorBrush Color="Black" Opacity=".7"/>
                            </Border.Background>
                            <TextBlock Text="{Binding MapName}" FontSize="20"/>
                        </Border>
                        <Border  Width="auto" Height="auto" CornerRadius="4" HorizontalAlignment="Right">
                            <Border.Background>
                                <SolidColorBrush Color="Black" Opacity=".7"/>
                            </Border.Background>
                            <TextBlock Text="{Binding Pp}" FontSize="20"/>
                        </Border>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Grid>
        <Rectangle Grid.Row="1" Fill="White"/>
        <Border Grid.Row="2"
                Background="{StaticResource RaspberryRed}"
                CornerRadius="17"
                Margin="20">
            <ItemsControl ItemsSource="{Binding BeatMaps}"
                          Margin="10 25">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Style="{StaticResource BeatMapExpander}">
                            <Expander.Header>
                                
                                <Border CornerRadius="5"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        Margin="0 0 0 20"
                                        Height="56"
                                        Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, 
                               AncestorType={x:Type Expander}}, Path=ActualWidth}">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding BgPath}"
                                                Stretch="UniformToFill"/>
                                </Border.Background>
                                <Grid Margin="15 0 9 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border HorizontalAlignment="Left"
                                            Background="#86000000"
                                            Width="130"
                                            VerticalAlignment="Center"
                                            Height="auto">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="26"
                                                   Padding="6 0 10 0"/>
                                    </Border>
                                    <Border HorizontalAlignment="Right"
                                            Background="#86000000"
                                            Width="auto"
                                            Grid.Column="1"
                                            Padding="2 2 4 2"
                                            VerticalAlignment="Center"
                                            Height="auto">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StarRate}"
                                                       FontSize="26"
                                                       Margin="0 0 20 0"/>
                                            <Image Source="/Assets/Images/Star.jpeg"  Width="24"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            </Expander.Header>
                            <Expander.Content>
                                    <Border BorderThickness="1" 
                                            Padding="10"
                                            CornerRadius="17">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding BgPath}"
                                                        Stretch="UniformToFill"/>                                     
                                        </Border.Background>
                                        <Grid HorizontalAlignment="Left">
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Border CornerRadius="10"
                                                    Background="#86000000"
                                                    Margin="0 0 0 20"
                                                    Padding="10 0">
                                                <StackPanel Height="auto" Width="187" Margin="6">
                                                    <TextBlock FontSize="26" Text="{Binding Name}"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontSize="18" Text="by "/>
                                                        <TextBlock FontSize="18" Text="{Binding Artist}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="0 25 0 0">
                                                        <TextBlock FontSize="18" Text="Mapper: " />
                                                        <TextBlock FontSize="18" Text="{Binding Mapper}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="1"
                                                    CornerRadius="10"
                                                    Background="#86000000"
                                                    Padding="10 8">
                                                <StackPanel Orientation="Horizontal">
                                                   <TextBlock FontSize="28" Text="played: "/>
                                                    <TextBlock FontSize="28" Text="{Binding PlayCount}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1"
                                                    CornerRadius="10"
                                                    Background="#86000000"
                                                    Width="auto"
                                                    Padding="7"
                                                    HorizontalAlignment="Left">
                                                <Grid Width="208" >
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition/>
                                                        <RowDefinition/>
                                                        <RowDefinition/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="26" HorizontalAlignment="Left" Text="{Binding Bpm}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" FontSize="18" HorizontalAlignment="Left" Text="{Binding Length}"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" FontSize="18" HorizontalAlignment="Left" Text="{Binding Hp}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" FontSize="26" HorizontalAlignment="Right" Text="{Binding StarRate}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="18" HorizontalAlignment="Right" Text="{Binding Ar}"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" FontSize="18" HorizontalAlignment="Right" Text="{Binding Cs}"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                            </Expander.Content>
                        </Expander>                            
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                
            </ItemsControl>
            
        </Border>
    </Grid>
</UserControl>
