<UserControl x:Class="OsuStat.UI.MVVM.View.MapCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OsuStat.UI.MVVM.View"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
       <Grid.Background>
           <ImageBrush ImageSource="{Binding Beatmap.Bg}"/>
       </Grid.Background> 
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource 86Black}"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="15"
                CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Beatmap.StarRate}"
                           FontSize="24"/>
                <Image Source="../../Assets/Images/Star.jpeg"
                       Height="25"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Left"
                    Margin="20">
            <Border CornerRadius="5"
                    Background="{StaticResource 86Black}"
                    Margin="0 0 0 4">
                <TextBlock Text="Beatmap.Artist" 
                           FontSize="16"/>
            </Border>
            <Border CornerRadius="5"
                    Background="{StaticResource 86Black}">
                <TextBlock Text="Beatmap.Name" 
                           FontSize="24"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
