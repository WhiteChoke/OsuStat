<UserControl x:Class="OsuStat.UI.MVVM.View.PlayCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OsuStat.UI.MVVM.View"
             mc:Ignorable="d"
             Background="{StaticResource LightGrayBackground}"
             d:DesignHeight="330" d:DesignWidth="330">
    <DockPanel>
        <Grid DockPanel.Dock="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock FontSize="16" Text="{Binding Play.MaxCombo, StringFormat='Combo: {0}'}"/>
            <TextBlock Grid.Row="1" FontSize="16" Text="{Binding Play.Accuracy, StringFormat='Accuracy: {0}'}"/>
            <TextBlock Grid.Row="1" HorizontalAlignment="Right" FontSize="16" Text="{Binding Play.PpGained, StringFormat='PP gained: {0}'}"/>
        </Grid>
            <ItemsControl DockPanel.Dock="Left" ItemsSource="{Binding Play.Mods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding}" Height="30"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        <Border Height="200"
                 Width="200"
                 CornerRadius="100"
                 Background="{StaticResource EllipseBlack}">
           <TextBlock Text="{Binding Play.Grade}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="64"/> 
        </Border>
    </DockPanel>
</UserControl>
