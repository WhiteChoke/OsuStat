<UserControl x:Class="OsuStat.UI.MVVM.View.PlayStatistic"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OsuStat.UI.MVVM.View"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Border Background="#90000000"
            CornerRadius="5"
            Margin="0 0 0 10">
        <Grid Margin="9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" FontSize="18" Margin="10 0" Text="{Binding MaxCombo, StringFormat='Combo: {0}'}" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10 0">
                <TextBlock FontSize="18" Margin="0 0 10 8" Text="{Binding PpGained, StringFormat='Pp gained: {0}'}" />
                <TextBlock FontSize="18" Text="{Binding Accuracy, StringFormat='Accuracy: {0}'}" />
            </StackPanel>
            <ItemsControl Grid.Row="2" ItemsSource="{Binding Mods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding}" Height="50" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Grid.Column="2" Grid.Row="0" Grid.RowSpan="3"
                       Text="{Binding Grade}" FontSize="64"
                       VerticalAlignment="Center"
                       TextAlignment="Center" />
        </Grid>
    </Border>
</UserControl>