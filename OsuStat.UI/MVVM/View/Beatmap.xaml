<UserControl x:Class="OsuStat.UI.Components.Beatmap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OsuStat.UI.Components"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    
    <Expander Style="{StaticResource BeatMapExpander}">
        <Expander.Header>
            <Border CornerRadius="5"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Margin="0 0 0 20"
                    Height="56"
                    Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, 
           AncestorType={x:Type Expander}}, Path=ActualWidth}">
            <Border.Background>
                <ImageBrush ImageSource="{Binding BgPath}"
                            Stretch="UniformToFill"/>
            </Border.Background>
            <Grid Margin="15 0 9 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border HorizontalAlignment="Left"
                        Background="#86000000"
                        Width="130"
                        VerticalAlignment="Center"
                        Height="auto">
                    <TextBlock Text="{Binding Name}"
                               FontSize="26"
                               Padding="6 0 10 0"/>
                </Border>
                <Border HorizontalAlignment="Right"
                        Background="#86000000"
                        Width="auto"
                        Grid.Column="1"
                        Padding="2 2 4 2"
                        VerticalAlignment="Center"
                        Height="auto">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding StarRate}"
                                   FontSize="26"
                                   Margin="0 0 20 0"/>
                        <Image Source="/Assets/Images/Star.jpeg"  Width="24"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        </Expander.Header>
        <Expander.Content>
            <StackPanel>
                <Border BorderThickness="1" 
                        Padding="10"
                        CornerRadius="5">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding BgPath}"
                                        Stretch="UniformToFill"/>                                     
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="10"
                                    Background="#86000000"
                                    Margin="0 0 0 20"
                                    Padding="10 0">
                                <StackPanel Height="auto" Width="187" Margin="6" HorizontalAlignment="Left">
                                    <TextBlock FontSize="26" Text="{Binding Name}"/>
                                    <TextBlock FontSize="18"
                                               Text="{Binding Artist, StringFormat='By {0}'}"/>
                                    <TextBlock FontSize="18"
                                               Margin="0 25 0 0"
                                               Text="{Binding Mapper, StringFormat='Mapper: {0}'}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1"
                                    CornerRadius="10"
                                    Background="#86000000"
                                    Padding="10 8">
                                <TextBlock FontSize="28"
                                           Text="{Binding PlayCount, StringFormat='played: {0}'}"/>
                            </Border>
                            <Border Grid.Column="1"
                                    CornerRadius="10"
                                    Background="#86000000"
                                    Width="auto"
                                    Padding="7"
                                    Height="auto"
                                    Margin="0 0 0 20"
                                    HorizontalAlignment="Right">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               FontSize="26" 
                                               HorizontalAlignment="Left"
                                                Text="{Binding Bpm, StringFormat='Bpm {0}'}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               FontSize="18" 
                                               HorizontalAlignment="Left"
                                                Text="{Binding Length, StringFormat='Length {0}'}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               FontSize="18" 
                                               HorizontalAlignment="Left" 
                                               Text="{Binding Hp, StringFormat='Hp {0}'}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Margin="30 0 0 0"
                                               FontSize="26" Text="{Binding StarRate}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" 
                                               Margin="30 0 0 0"
                                               FontSize="18" 
                                               Text="{Binding Ar, StringFormat='Ar {0}'}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" 
                                               Margin="30 0 0 0"
                                               FontSize="18" 
                                               Text="{Binding Cs, StringFormat='Cs {0}'}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <Border Background="#86000000"
                        CornerRadius="5"
                        Margin="0 12">
                    <Grid Margin="9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" FontSize="20" Margin="0 0 0 8" Text="{Binding Date, StringFormat='Date {0}'}"/>
                        <TextBlock Grid.Row="1" FontSize="16" Text="{Binding MaxCombo, StringFormat='Max combo {0}'}"/>
                        <TextBlock Grid.Row="2" FontSize="16" Text="{Binding PpGained, StringFormat='Pp gained {0}'}"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Expander.Content>
    </Expander>    
</UserControl>
