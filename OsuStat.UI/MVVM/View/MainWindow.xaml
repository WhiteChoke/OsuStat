<Window x:Class="OsuStat.UI.MVVM.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OsuStat" Height="800" Width="1200"
        Icon="../../Assets/AmazingPfpForPerfectApplication.ico"
        Background="{StaticResource BackgroundBlack}"
        WindowStyle="None"
        MouseLeftButtonDown="MainWindow_OnMouseLeftButtonDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal">
            <Button Width="40"
                    FontSize="30"
                    BorderBrush="Transparent"
                    Background="Transparent"
                    Content="..." />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="40"
                    BorderBrush="Transparent"
                    Background="Transparent"
                    Content="━"
                    HorizontalAlignment="Right"
                    Click="btnMinimized_Click" />
            <Button Width="40"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Content="🗖" 
                    Click="btnMaximize_Click"/>
            <Button Width="40"
                    BorderBrush="Transparent"
                    Background="Transparent"
                    Content="✖"
                    HorizontalAlignment="Right"
                    Click="btnClose_click" />
        </StackPanel>
        <ContentControl Grid.Row="1" Grid.ColumnSpan="2"
                        Content="{Binding Navigation.CurrentView}" />
    </Grid>
</Window>