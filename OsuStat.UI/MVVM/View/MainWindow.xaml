<Window x:Class="OsuStat.UI.MVVM.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OsuStat" Height="850 " Width="572" 
        Icon="../../Assets/AmazingPfpForPerfectApplication.ico"
        Background="{StaticResource BackgroundBlack}"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        MouseLeftButtonDown="MainWindow_OnMouseLeftButtonDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" 
                    Background="{StaticResource RaspberryRed}">
            <Button BorderBrush="Transparent" Height="40" Width="40"
                    Command="{Binding NavigateToSettingsCommand}">
                <Button.Background>
                    <ImageBrush ImageSource="../../Assets/Images/Settings.png"/>
                </Button.Background>
            </Button>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal"
                    Background="{StaticResource RaspberryRed}">
            <Button Width="40" 
                    BorderBrush="Transparent"
                    Background="Transparent"
                    Content="━"
                    HorizontalAlignment="Right"
                    Click="btnMinimized_Click"/>
            <Button Width="40" 
                    BorderBrush="Transparent"            
                    Background="Transparent"
                    Content="✖"
                    HorizontalAlignment="Right"
                    Click="btnClose_click"/>
        </StackPanel>
        <ContentControl Grid.Row="1" Grid.ColumnSpan="2"
                        Content="{Binding Navigation.CurrentView}"/>
    </Grid>
</Window>
